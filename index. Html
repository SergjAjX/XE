<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Диабет-Помощник: ХЕ + Сахар</title>
    <style>
        :root {
            --primary: #27ae60;
            --warning: #f39c12;
            --danger: #e74c3c;
            --bg: #f4f7f6;
            --card: #ffffff;
            --text: #2c3e50;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }
        .app-container {
            width: 100%;
            max-width: 420px;
            background: var(--card);
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            overflow: hidden;
            padding-bottom: 20px;
        }
        .header {
            background: var(--primary);
            color: white;
            padding: 20px;
            text-align: center;
        }
        .header h1 { margin: 0; font-size: 18px; }
        
        .settings-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            padding: 15px;
            background: #e8f8f5;
            border-bottom: 1px solid #ddd;
        }
        .setting-item { font-size: 12px; }
        .setting-item input {
            width: 100%;
            padding: 6px;
            border-radius: 5px;
            border: 1px solid #ccc;
            text-align: center;
            font-size: 14px;
            box-sizing: border-box;
        }
        
        .main-form { padding: 20px; }
        label { font-size: 14px; color: #7f8c8d; margin-bottom: 5px; display: block; }
        select, input[type="number"] {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-size: 16px;
            box-sizing: border-box;
        }
        
        .sugar-input-group {
            display: flex;
            gap: 10px;
        }
        .sugar-input-group > div { flex: 1; }
        
        button.calc-btn {
            width: 100%;
            padding: 15px;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(39, 174, 96, 0.3);
        }
        button.calc-btn:active { transform: scale(0.98); }

        .result-card {
            margin: 20px;
            padding: 20px;
            background: #fff;
            border: 2px solid var(--primary);
            border-radius: 15px;
            text-align: center;
            display: none;
        }
        .result-card.warning { border-color: var(--warning); background: #fef5e7; }
        .result-card.danger { border-color: var(--danger); background: #fdedec; }
        
        .big-number { font-size: 42px; font-weight: bold; margin: 5px 0; }
        .text-green { color: var(--primary); }
        .text-red { color: var(--danger); }
        .text-orange { color: var(--warning); }
        .sub-text { color: #7f8c8d; font-size: 14px; }
        
        .correction-info {
            margin-top: 15px;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 8px;
            font-size: 13px;
            text-align: left;
        }

        .history-section { padding: 0 20px; }
        .history-title { 
            font-size: 18px; font-weight: bold; margin: 20px 0 10px; 
            display: flex; justify-content: space-between; align-items: center;
        }
        .clear-btn { font-size: 12px; color: var(--danger); background: none; border: none; cursor: pointer; }
        
        .history-list {
            list-style: none; padding: 0; margin: 0;
            max-height: 200px; overflow-y: auto; border-top: 1px solid #eee;
        }
        .history-item {
            display: flex; justify-content: space-between; align-items: center;
            padding: 12px 0; border-bottom: 1px solid #eee; font-size: 14px;
        }
        .history-left { display: flex; flex-direction: column; }
        .history-time { font-size: 11px; color: #999; }
        .history-right { text-align: right; }
        .history-he { font-weight: bold; color: var(--primary); }
        .history-ins { font-size: 12px; color: var(--danger); }
        .history-sugar { font-size: 12px; color: #666; }
        
        .status-badge {
            padding: 3px 8px; border-radius: 10px; font-size: 11px; font-weight: bold;
        }
        .status-ok { background: #d5f5e3; color: #27ae60; }
        .status-high { background: #fdebd0; color: #f39c12; }
        .status-low { background: #fadbd8; color: #e74c3c; }

        .warning-box {
            margin: 10px 20px; padding: 12px; border-radius: 10px; font-size: 13px;
            display: none; text-align: center;
        }
        .warning-box.show { display: block; }
        .warning-box.hypo { background: #fadbd8; color: #922b21; border: 1px solid #e74c3c; }
        .warning-box.hyper { background: #fdebd0; color: #9a6b00; border: 1px solid #f39c12; }
    </style>
</head>
<body>

<div class="app-container">
    <div class="header">
        <h1>🩸 Диабет-Помощник: ХЕ + Сахар</h1>
    </div>

    <!-- Настройки -->
    <div class="settings-grid">
        <div class="setting-item">
            <label>Цель сахара (мин)</label>
            <input type="number" id="targetMin" value="5.0" step="0.1">
        </div>
        <div class="setting-item">
            <label>Цель сахара (макс)</label>
            <input type="number" id="targetMax" value="7.0" step="0.1">
        </div>
        <div class="setting-item">
            <label>Коэф. на ХЕ (ед/ХЕ)</label>
            <input type="number" id="carbFactor" value="1.0" step="0.1">
        </div>
        <div class="setting-item">
            <label>Чувствит. к инсулину</label>
            <input type="number" id="sensitivity" value="2.0" step="0.1" title="На сколько ммоль/л снижает 1 ед инсулина">
        </div>
    </div>

    <div class="main-form">
        <label>Продукт</label>
        <select id="productSelect">
            <option value="50">Хлеб белый (50г угл/100г)</option>
            <option value="40">Хлеб черный (40г)</option>
            <option value="10">Яблоко (10г)</option>
            <option value="21">Банан (21г)</option>
            <option value="25">Гречка вареная (25г)</option>
            <option value="20">Макароны вареные (20г)</option>
            <option value="5">Картофель вареный (5г)</option>
            <option value="10">Молоко (10г)</option>
            <option value="3">Огурцы (3г)</option>
            <option value="90">Сахар/Мед (90г)</option>
        </select>

        <label>Вес порции (грамм)</label>
        <input type="number" id="weightInput" placeholder="Например: 150">

        <label>Текущий сахар крови (ммоль/л)</label>
        <div class="sugar-input-group">
            <div>
                <input type="number" id="currentSugar" placeholder="Напр: 8.5" step="0.1">
            </div>
        </div>

        <button class="calc-btn" onclick="calculateFull()">💉 Рассчитать дозу</button>
    </div>

    <!-- Предупреждения -->
    <div id="warningBox" class="warning-box"></div>

    <!-- Результат -->
    <div id="resultCard" class="result-card">
        <div class="sub-text">Хлебных единиц:</div>
        <div class="big-number text-green"><span id="resHE">0</span> ХЕ</div>
        
        <div style="margin: 15px 0; border-top: 1px dashed #ccc; padding-top: 15px;">
            <div class="sub-text">На еду:</div>
            <div style="font-size: 24px;"><span id="resFoodInsulin">0</span> ед.</div>
        </div>
        
        <div id="correctionBlock">
            <div class="sub-text">Коррекция на сахар:</div>
            <div style="font-size: 24px;" id="resCorrection">±0 ед.</div>
        </div>
        
        <hr style="border: 0; border-top: 2px solid #eee; margin: 15px 0;">
        
        <div class="sub-text">💉 ИТОГО ввести:</div>
        <div class="big-number text-red"><span id="resTotalInsulin">0</span> ед.</div>
        
        <div id="correctionInfo" class="correction-info"></div>
    </div>

    <!-- История -->
    <div class="history-section">
        <div class="history-title">
            📋 История
            <button class="clear-btn" onclick="clearHistory()">Очистить</button>
        </div>
        <ul id="historyList" class="history-list"></ul>
    </div>
</div>

<script>
    // Загрузка при старте
    document.addEventListener('DOMContentLoaded', () => {
        loadHistory();
        loadSettings();
    });

    function saveSettings() {
        const settings = {
            targetMin: document.getElementById('targetMin').value,
            targetMax: document.getElementById('targetMax').value,
            carbFactor: document.getElementById('carbFactor').value,
            sensitivity: document.getElementById('sensitivity').value
        };
        localStorage.setItem('diabSettings', JSON.stringify(settings));
    }

    function loadSettings() {
        const saved = JSON.parse(localStorage.getItem('diabSettings'));
        if (saved) {
            document.getElementById('targetMin').value = saved.targetMin || 5.0;
            document.getElementById('targetMax').value = saved.targetMax || 7.0;
            document.getElementById('carbFactor').value = saved.carbFactor || 1.0;
            document.getElementById('sensitivity').value = saved.sensitivity || 2.0;
        }
        // Сохраняем при изменении любого поля настроек
        document.querySelectorAll('.settings-grid input').forEach(input => {
            input.addEventListener('change', saveSettings);
        });
    }

    function calculateFull() {
        saveSettings(); // Сохраняем настройки перед расчетом
        
        // === 1. Сбор данных ===
        const carbsPer100 = parseFloat(document.getElementById('productSelect').value);
        const weight = parseFloat(document.getElementById('weightInput').value);
        const currentSugar = parseFloat(document.getElementById('currentSugar').value);
        
        const targetMin = parseFloat(document.getElementById('targetMin').value);
        const targetMax = parseFloat(document.getElementById('targetMax').value);
        const carbFactor = parseFloat(document.getElementById('carbFactor').value);
        const sensitivity = parseFloat(document.getElementById('sensitivity').value);
        
        const productName = document.getElementById('productSelect').options[document.getElementById('productSelect').selectedIndex].text.split('(')[0].trim();

        if (!weight || weight <= 0) { alert("Введите вес продукта!"); return; }
        if (!currentSugar || currentSugar <= 0) { alert("Введите текущий сахар!"); return; }
        if (sensitivity <= 0) { alert("Проверьте коэффициент чувствительности!"); return; }

        // === 2. Расчет ХЕ и базовой дозы ===
        const totalCarbs = (carbsPer100 * weight) / 100;
        const he = totalCarbs / 12; // 1 ХЕ = 12г углеводов
        const foodInsulin = he * carbFactor;

        // === 3. Расчет коррекции ===
        const targetAvg = (targetMin + targetMax) / 2;
        const sugarDiff = currentSugar - targetAvg;
        let correctionInsulin = sugarDiff / sensitivity;
        
        // Округляем коррекцию до 0.5 для удобства
        correctionInsulin = Math.round(correctionInsulin * 2) / 2;

        // === 4. Итоговая доза ===
        let totalInsulin = foodInsulin + correctionInsulin;
        
        // Защита от отрицательной дозы
        if (totalInsulin < 0) totalInsulin = 0;
        totalInsulin = Math.round(totalInsulin * 10) / 10; // Округление до 0.1

        // === 5. Определение статуса сахара ===
        let sugarStatus = 'ok', statusText = '', warningMsg = '';
        if (currentSugar < targetMin) {
            sugarStatus = 'low';
            statusText = '🔴 Гипогликемия!';
            warningMsg = '⚠️ Сахар НИЗКИЙ! Сначала съешьте быстрые углеводы. Инсулин уменьшен.';
        } else if (currentSugar > targetMax) {
            sugarStatus = 'high';
            statusText = '🟡 Гипергликемия';
            warningMsg = sugarDiff > 4 ? '⚠️ Сахар ВЫСОКИЙ! Проверьте кетоны при сахаре >15 ммоль/л.' : '💡 Добавлена коррекция на высокий сахар.';
        } else {
            statusText = '🟢 В целевом диапазоне';
        }

        // === 6. Отображение результата ===
        const resultCard = document.getElementById('resultCard');
        resultCard.className = 'result-card'; // сброс классов
        if (sugarStatus === 'low') resultCard.classList.add('danger');
        else if (sugarStatus === 'high') resultCard.classList.add('warning');
        
        document.getElementById('resHE').innerText = he.toFixed(2);
        document.getElementById('resFoodInsulin').innerText = foodInsulin.toFixed(1);
        
        const corrSign = correctionInsulin >= 0 ? '+' : '';
        document.getElementById('resCorrection').innerText = `${corrSign}${correctionInsulin.toFixed(1)} ед.`;
        document.getElementById('resCorrection').className = correctionInsulin > 0 ? 'text-red' : (correctionInsulin < 0 ? 'text-green' : '');
        
        document.getElementById('resTotalInsulin').innerText = totalInsulin.toFixed(1);
        
        // Блок информации о коррекции
        const corrInfo = document.getElementById('correctionInfo');
        corrInfo.innerHTML = `
            <strong>Логика расчета:</strong><br>
            • Цель: ${targetMin}-${targetMax} ммоль/л (среднее: ${targetAvg})<br>
            • Отклонение: ${sugarDiff >= 0 ? '+' : ''}${sugarDiff.toFixed(1)} ммоль/л<br>
            • Чувствительность: 1 ед. снижает на ${sensitivity} ммоль/л
        `;
        
        // Предупреждение
        const warningBox = document.getElementById('warningBox');
        if (warningMsg) {
            warningBox.className = `warning-box show ${sugarStatus === 'low' ? 'hypo' : 'hyper'}`;
            warningBox.innerText = warningMsg;
        } else {
            warningBox.className = 'warning-box';
        }
        
        resultCard.style.display = 'block';

        // === 7. Сохранение в историю ===
        addToHistory({
            name: productName,
            weight: weight,
            he: he.toFixed(2),
            sugar: currentSugar,
            sugarStatus: statusText,
            foodInsulin: foodInsulin.toFixed(1),
            correction: correctionInsulin.toFixed(1),
            totalInsulin: totalInsulin.toFixed(1),
            time: new Date().toLocaleTimeString('ru-RU', {hour: '2-digit', minute:'2-digit'})
        });
    }

    function addToHistory(entry) {
        const history = JSON.parse(localStorage.getItem('diabHistory')) || [];
        history.unshift(entry);
        // Храним только последние 50 записей
        if (history.length > 50) history.pop();
        localStorage.setItem('diabHistory', JSON.stringify(history));
        renderHistory();
    }

    function renderHistory() {
        const list = document.getElementById('historyList');
        const history = JSON.parse(localStorage.getItem('diabHistory')) || [];
        
        list.innerHTML = '';
        
        if (history.length === 0) {
            list.innerHTML = '<li style="padding:15px; color:#999; text-align:center">История пуста</li>';
            return;
        }

        // Считаем итоги
        let totalHe = 0, totalIns = 0;
        
        history.forEach(item => {
            totalHe += parseFloat(item.he);
            totalIns += parseFloat(item.totalInsulin);
            
            const li = document.createElement('li');
            li.className = 'history-item';
            li.innerHTML = `
                <div class="history-left">
                    <strong>${item.name}</strong>
                    <span class="history-time">${item.time} • ${item.sugar} ммоль/л <span class="status-badge status-${item.sugarStatus.includes('Низкий')?'low':item.sugarStatus.includes('Высокий')?'high':'ok'}">${item.sugarStatus}</span></span>
                </div>
                <div class="history-right">
                    <div class="history-he">${item.he} ХЕ</div>
                    <div class="history-ins">💉 ${item.totalInsulin} ед.</div>
                </div>
            `;
            list.appendChild(li);
        });
        
        // Итоговая строка
        const totalLi = document.createElement('li');
        totalLi.style.background = '#f8f9fa';
        totalLi.style.padding = '12px';
        totalLi.style.fontWeight = 'bold';
        totalLi.style.borderRadius = '8px';
        totalLi.style.marginBottom = '10px';
        totalLi.innerHTML = `
            <div>📊 Итого:</div>
            <div style="color:var(--primary)">${totalHe.toFixed(1)} ХЕ</div>
            <div style="color:var(--danger)">💉 ${totalIns.toFixed(1)} ед.</div>
        `;
        list.insertBefore(totalLi, list.firstChild);
    }

    function clearHistory() {
        if(confirm('Удалить ВСЮ историю расчетов?')) {
            localStorage.removeItem('diabHistory');
            renderHistory();
        }
    }
</script>

</body>
</html>
