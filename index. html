<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Диабет-Помощник: ХЕ + Сахар + Свои продукты</title>
    <style>
        :root {
            --primary: #27ae60;
            --primary-dark: #1e8449;
            --warning: #f39c12;
            --danger: #e74c3c;
            --bg: #f4f7f6;
            --card: #ffffff;
            --text: #2c3e50;
            --gray: #95a5a6;
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }
        .app-container {
            width: 100%;
            max-width: 450px;
            background: var(--card);
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            overflow: hidden;
            padding-bottom: 20px;
        }
        .header {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            padding: 20px;
            text-align: center;
        }
        .header h1 { margin: 0; font-size: 18px; }
        .header p { margin: 5px 0 0; opacity: 0.9; font-size: 12px; }
        
        .settings-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            padding: 15px;
            background: #e8f8f5;
            border-bottom: 1px solid #ddd;
        }
        .setting-item { font-size: 12px; }
        .setting-item label { font-size: 11px; color: var(--gray); margin-bottom: 3px; }
        .setting-item input {
            width: 100%;
            padding: 8px;
            border-radius: 6px;
            border: 1px solid #ccc;
            text-align: center;
            font-size: 14px;
        }
        
        .main-form { padding: 20px; }
        label { font-size: 14px; color: var(--gray); margin-bottom: 5px; display: block; }
        
        .product-selector {
            display: flex;
            gap: 8px;
            margin-bottom: 15px;
        }
        select {
            flex: 1;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-size: 15px;
            background: white;
        }
        .btn-add-product {
            padding: 12px 16px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 20px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-add-product:hover { background: var(--primary-dark); transform: scale(1.05); }
        
        input[type="number"] {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-size: 16px;
        }
        
        .btn-calc {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(39, 174, 96, 0.3);
            transition: transform 0.2s;
        }
        .btn-calc:active { transform: scale(0.98); }

        .result-card {
            margin: 20px;
            padding: 20px;
            background: #fff;
            border: 2px solid var(--primary);
            border-radius: 15px;
            text-align: center;
            display: none;
            animation: slideIn 0.3s ease;
        }
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .result-card.warning { border-color: var(--warning); background: #fef5e7; }
        .result-card.danger { border-color: var(--danger); background: #fdedec; }
        
        .big-number { font-size: 40px; font-weight: bold; margin: 5px 0; }
        .text-green { color: var(--primary); }
        .text-red { color: var(--danger); }
        .text-orange { color: var(--warning); }
        .sub-text { color: var(--gray); font-size: 13px; }
        
        .correction-info {
            margin-top: 15px;
            padding: 12px;
            background: #f8f9fa;
            border-radius: 8px;
            font-size: 12px;
            text-align: left;
            line-height: 1.6;
        }

        .warning-box {
            margin: 0 20px 10px; padding: 12px; border-radius: 10px; font-size: 13px;
            display: none; text-align: center; font-weight: 500;
        }
        .warning-box.show { display: block; animation: shake 0.5s; }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }
        .warning-box.hypo { background: #fadbd8; color: #922b21; border: 1px solid var(--danger); }
        .warning-box.hyper { background: #fdebd0; color: #9a6b00; border: 1px solid var(--warning); }

        .history-section { padding: 0 20px; }
        .history-title { 
            font-size: 16px; font-weight: bold; margin: 20px 0 10px; 
            display: flex; justify-content: space-between; align-items: center;
        }
        .btn-clear { font-size: 12px; color: var(--danger); background: none; border: none; cursor: pointer; padding: 5px; }
        
        .history-list {
            list-style: none; padding: 0; margin: 0;
            max-height: 250px; overflow-y: auto;
        }
        .history-item {
            display: flex; justify-content: space-between; align-items: center;
            padding: 12px 0; border-bottom: 1px solid #eee; font-size: 13px;
        }
        .history-left { display: flex; flex-direction: column; gap: 3px; }
        .history-time { font-size: 11px; color: var(--gray); }
        .history-right { text-align: right; }
        .history-he { font-weight: bold; color: var(--primary); }
        .history-ins { font-size: 12px; color: var(--danger); }
        
        .status-badge {
            padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: bold;
            display: inline-block;
        }
        .status-ok { background: #d5f5e3; color: #27ae60; }
        .status-high { background: #fdebd0; color: #f39c12; }
        .status-low { background: #fadbd8; color: #e74c3c; }

        /* === МОДАЛЬНОЕ ОКНО === */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            animation: fadeIn 0.2s;
        }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        
        .modal {
            background: white;
            padding: 25px;
            border-radius: 20px;
            width: 90%;
            max-width: 350px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        }
        .modal h2 { margin: 0 0 20px; font-size: 20px; color: var(--text); text-align: center; }
        .modal label { font-size: 13px; color: var(--gray); margin-bottom: 5px; }
        .modal input {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-size: 16px;
        }
        .modal-buttons {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }
        .modal-btn {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
        }
        .modal-btn.cancel { background: #ecf0f1; color: var(--text); }
        .modal-btn.save { background: var(--primary); color: white; }
        
        /* Управление продуктами */
        .products-manage {
            margin-top: 10px;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 10px;
            font-size: 12px;
        }
        .products-manage summary {
            cursor: pointer;
            color: var(--primary);
            font-weight: bold;
            padding: 5px;
        }
        .custom-product-list {
            list-style: none;
            padding: 10px;
            margin: 0;
            max-height: 150px;
            overflow-y: auto;
        }
        .custom-product-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px;
            background: white;
            margin-bottom: 5px;
            border-radius: 6px;
            font-size: 13px;
        }
        .btn-delete {
            background: #fadbd8;
            color: var(--danger);
            border: none;
            padding: 4px 8px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 11px;
        }
        .btn-delete:hover { background: var(--danger); color: white; }

        .total-summary {
            margin: 10px 20px;
            padding: 15px;
            background: linear-gradient(135deg, #e8f8f5, #d5f5e3);
            border-radius: 12px;
            display: flex;
            justify-content: space-around;
            font-weight: bold;
        }
        .total-summary div { text-align: center; }
        .total-summary span { display: block; font-size: 18px; }
        .total-summary small { font-size: 11px; color: var(--gray); font-weight: normal; }
    </style>
</head>
<body>

<div class="app-container">
    <div class="header">
        <h1>🩸 Диабет-Помощник</h1>
        <p>ХЕ + Сахар + Свои продукты</p>
    </div>

    <!-- Настройки -->
    <div class="settings-grid">
        <div class="setting-item">
            <label>Цель (мин)</label>
            <input type="number" id="targetMin" value="5.0" step="0.1">
        </div>
        <div class="setting-item">
            <label>Цель (макс)</label>
            <input type="number" id="targetMax" value="7.0" step="0.1">
        </div>
        <div class="setting-item">
            <label>Коэф. на ХЕ</label>
            <input type="number" id="carbFactor" value="1.0" step="0.1">
        </div>
        <div class="setting-item">
            <label>Чувствит. к инсулину</label>
            <input type="number" id="sensitivity" value="2.0" step="0.1">
        </div>
    </div>

    <div class="main-form">
        <label>Продукт</label>
        <div class="product-selector">
            <select id="productSelect"></select>
            <button class="btn-add-product" onclick="openModal()" title="Добавить свой продукт">+</button>
        </div>

        <details class="products-manage">
            <summary>📝 Управление моими продуктами</summary>
            <ul id="customProductList" class="custom-product-list"></ul>
        </details>

        <label style="margin-top: 15px;">Вес порции (грамм)</label>
        <input type="number" id="weightInput" placeholder="Например: 150">

        <label>Текущий сахар крови (ммоль/л)</label>
        <input type="number" id="currentSugar" placeholder="Напр: 8.5" step="0.1">

        <button class="btn-calc" onclick="calculateFull()">💉 Рассчитать дозу</button>
    </div>

    <!-- Предупреждения -->
    <div id="warningBox" class="warning-box"></div>

    <!-- Результат -->
    <div id="resultCard" class="result-card">
        <div class="sub-text">🍞 Хлебных единиц:</div>
        <div class="big-number text-green"><span id="resHE">0</span> ХЕ</div>
        
        <div style="margin: 15px 0; border-top: 1px dashed #ccc; padding-top: 15px;">
            <div class="sub-text">На еду:</div>
            <div style="font-size: 24px;"><span id="resFoodInsulin">0</span> ед.</div>
        </div>
        
        <div id="correctionBlock">
            <div class="sub-text">Коррекция на сахар:</div>
            <div style="font-size: 24px;" id="resCorrection">±0 ед.</div>
        </div>
        
        <hr style="border: 0; border-top: 2px solid #eee; margin: 15px 0;">
        
        <div class="sub-text">💉 ИТОГО ввести:</div>
        <div class="big-number text-red"><span id="resTotalInsulin">0</span> ед.</div>
        
        <div id="correctionInfo" class="correction-info"></div>
    </div>

    <!-- История -->
    <div class="history-section">
        <div class="history-title">
            📋 История
            <button class="btn-clear" onclick="clearHistory()">Очистить</button>
        </div>
        <ul id="historyList" class="history-list"></ul>
        
        <div class="total-summary">
            <div><span id="totalHe">0</span><small>ХЕ</small></div>
            <div><span id="totalIns">0</span><small>ед.</small></div>
            <div><span id="totalRecords">0</span><small>записей</small></div>
        </div>
    </div>
</div>

<!-- Модальное окно добавления продукта -->
<div id="productModal" class="modal-overlay">
    <div class="modal">
        <h2>🥗 Новый продукт</h2>
        <label>Название продукта</label>
        <input type="text" id="newProductName" placeholder="Например: Борщ домашний">
        
        <label>Углеводы на 100г (грамм)</label>
        <input type="number" id="newProductCarbs" placeholder="Например: 8" step="0.1">
        
        <div class="modal-buttons">
            <button class="modal-btn cancel" onclick="closeModal()">Отмена</button>
            <button class="modal-btn save" onclick="saveCustomProduct()">Сохранить</button>
        </div>
    </div>
</div>

<script>
    // === Стандартные продукты ===
    const defaultProducts = [
        { name: "Хлеб белый", carbs: 50 },
        { name: "Хлеб черный/Бородинский", carbs: 40 },
        { name: "Хлеб цельнозерновой", carbs: 35 },
        { name: "Яблоко", carbs: 10 },
        { name: "Банан", carbs: 21 },
        { name: "Груша", carbs: 10 },
        { name: "Апельсин", carbs: 8 },
        { name: "Виноград", carbs: 17 },
        { name: "Арбуз", carbs: 6 },
        { name: "Гречка вареная", carbs: 25 },
        { name: "Рис вареный", carbs: 28 },
        { name: "Овсянка вареная", carbs: 15 },
        { name: "Макароны вареные", carbs: 20 },
        { name: "Картофель вареный", carbs: 16 },
        { name: "Картофель жареный", carbs: 35 },
        { name: "Молоко 2.5%", carbs: 5 },
        { name: "Кефир", carbs: 4 },
        { name: "Творог", carbs: 3 },
        { name: "Сыр твердый", carbs: 0 },
        { name: "Огурцы", carbs: 3 },
        { name: "Помидоры", carbs: 4 },
        { name: "Морковь вареная", carbs: 7 },
        { name: "Свекла вареная", carbs: 10 },
        { name: "Капуста", carbs: 5 },
        { name: "Курица/Мясо", carbs: 0 },
        { name: "Рыба", carbs: 0 },
        { name: "Яйца", carbs: 1 },
        { name: "Сахар", carbs: 100 },
        { name: "Мёд", carbs: 80 },
        { name: "Шоколад молочный", carbs: 55 },
        { name: "Печенье", carbs: 65 },
        { name: "Торт/Пирожное", carbs: 50 },
        { name: "Мороженое", carbs: 25 },
        { name: "Сок фруктовый", carbs: 12 },
        { name: "Кола/Газировка", carbs: 11 }
    ];

    // === Инициализация ===
    document.addEventListener('DOMContentLoaded', () => {
        loadSettings();
        loadCustomProducts();
        renderProductSelect();
        renderCustomProductList();
        loadHistory();
    });

    // === Настройки ===
    function saveSettings() {
        const settings = {
            targetMin: document.getElementById('targetMin').value,
            targetMax: document.getElementById('targetMax').value,
            carbFactor: document.getElementById('carbFactor').value,
            sensitivity: document.getElementById('sensitivity').value
        };
        localStorage.setItem('diabSettings', JSON.stringify(settings));
    }

    function loadSettings() {
        const saved = JSON.parse(localStorage.getItem('diabSettings'));
        if (saved) {
            document.getElementById('targetMin').value = saved.targetMin || 5.0;
            document.getElementById('targetMax').value = saved.targetMax || 7.0;
            document.getElementById('carbFactor').value = saved.carbFactor || 1.0;
            document.getElementById('sensitivity').value = saved.sensitivity || 2.0;
        }
        document.querySelectorAll('.settings-grid input').forEach(input => {
            input.addEventListener('change', saveSettings);
        });
    }

    // === Управление продуктами ===
    function getCustomProducts() {
        return JSON.parse(localStorage.getItem('customProducts')) || [];
    }

    function saveCustomProducts(products) {
        localStorage.setItem('customProducts', JSON.stringify(products));
    }

    function loadCustomProducts() {
        // Загружаем из localStorage (ничего делать не нужно, getCustomProducts() сделает это)
    }

    function renderProductSelect() {
        const select = document.getElementById('productSelect');
        select.innerHTML = '';
        
        // Стандартные продукты
        const optgroup1 = document.createElement('optgroup');
        optgroup1.label = '📚 Стандартные продукты';
        defaultProducts.forEach(p => {
            const option = document.createElement('option');
            option.value = p.carbs;
            option.textContent = `${p.name} (${p.carbs}г)`;
            optgroup1.appendChild(option);
        });
        select.appendChild(optgroup1);
        
        // Пользовательские продукты
        const customProducts = getCustomProducts();
        if (customProducts.length > 0) {
            const optgroup2 = document.createElement('optgroup');
            optgroup2.label = '⭐ Мои продукты';
            customProducts.forEach(p => {
                const option = document.createElement('option');
                option.value = p.carbs;
                option.textContent = `${p.name} (${p.carbs}г)`;
                option.dataset.custom = 'true';
                option.dataset.name = p.name;
                optgroup2.appendChild(option);
            });
            select.appendChild(optgroup2);
        }
    }

    function renderCustomProductList() {
        const list = document.getElementById('customProductList');
        const customProducts = getCustomProducts();
        
        if (customProducts.length === 0) {
            list.innerHTML = '<li style="color:#999; padding:5px;">Нет добавленных продуктов</li>';
            return;
        }
        
        list.innerHTML = '';
        customProducts.forEach((p, index) => {
            const li = document.createElement('li');
            li.className = 'custom-product-item';
            li.innerHTML = `
                <span><strong>${p.name}</strong> — ${p.carbs}г/100г</span>
                <button class="btn-delete" onclick="deleteCustomProduct(${index})">✕</button>
            `;
            list.appendChild(li);
        });
    }

    function openModal() {
        document.getElementById('productModal').style.display = 'flex';
        document.getElementById('newProductName').value = '';
        document.getElementById('newProductCarbs').value = '';
        document.getElementById('newProductName').focus();
    }

    function closeModal() {
        document.getElementById('productModal').style.display = 'none';
    }

    function saveCustomProduct() {
        const name = document.getElementById('newProductName').value.trim();
        const carbs = parseFloat(document.getElementById('newProductCarbs').value);
        
        if (!name) {
            alert('Введите название продукта!');
            return;
        }
        if (!carbs || carbs < 0) {
            alert('Введите корректное значение углеводов!');
            return;
        }
        
        const customProducts = getCustomProducts();
        customProducts.push({ name, carbs });
        saveCustomProducts(customProducts);
        
        renderProductSelect();
        renderCustomProductList();
        closeModal();
        
        // Автоматически выбираем новый продукт
        const select = document.getElementById('productSelect');
        for (let i = 0; i < select.options.length; i++) {
            if (select.options[i].text.includes(name)) {
                select.selectedIndex = i;
                break;
            }
        }
    }

    function deleteCustomProduct(index) {
        if (!confirm('Удалить этот продукт?')) return;
        
        const customProducts = getCustomProducts();
        customProducts.splice(index, 1);
        saveCustomProducts(customProducts);
        
        renderProductSelect();
        renderCustomProductList();
    }

    // Закрытие модального окна по клику вне его
    document.getElementById('productModal').addEventListener('click', (e) => {
        if (e.target.id === 'productModal') closeModal();
    });

    // Enter в модальном окне
    document.querySelectorAll('.modal input').forEach(input => {
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') saveCustomProduct();
        });
    });

    // === Расчет ===
    function calculateFull() {
        saveSettings();
        
        const select = document.getElementById('productSelect');
        const selectedOption = select.options[select.selectedIndex];
        const carbsPer100 = parseFloat(select.value);
        const productName = selectedOption.text.split('(')[0].trim();
        
        const weight = parseFloat(document.getElementById('weightInput').value);
        const currentSugar = parseFloat(document.getElementById('currentSugar').value);
        
        const targetMin = parseFloat(document.getElementById('targetMin').value);
        const targetMax = parseFloat(document.getElementById('targetMax').value);
        const carbFactor = parseFloat(document.getElementById('carbFactor').value);
        const sensitivity = parseFloat(document.getElementById('sensitivity').value);

        if (!weight || weight <= 0) { alert("Введите вес продукта!"); return; }
        if (!currentSugar || currentSugar <= 0) { alert("Введите текущий сахар!"); return; }
        if (sensitivity <= 0) { alert("Проверьте коэффициент чувствительности!"); return; }

        // Расчет ХЕ
        const totalCarbs = (carbsPer100 * weight) / 100;
        const he = totalCarbs / 12;
        const foodInsulin = he * carbFactor;

        // Коррекция
        const targetAvg = (targetMin + targetMax) / 2;
        const sugarDiff = currentSugar - targetAvg;
        let correctionInsulin = sugarDiff / sensitivity;
        correctionInsulin = Math.round(correctionInsulin * 2) / 2;

        // Итог
        let totalInsulin = foodInsulin + correctionInsulin;
        if (totalInsulin < 0) totalInsulin = 0;
        totalInsulin = Math.round(totalInsulin * 10) / 10;

        // Статус
        let sugarStatus = 'ok', statusText = '', warningMsg = '';
        if (currentSugar < targetMin) {
            sugarStatus = 'low';
            statusText = '🔴 Низкий';
            warningMsg = '⚠️ ГИПОГЛИКЕМИЯ! Сначала съешьте 15г быстрых углеводов. Инсулин уменьшен.';
        } else if (currentSugar > targetMax) {
            sugarStatus = 'high';
            statusText = '🟡 Высокий';
            warningMsg = sugarDiff > 4 ? '⚠️ Сахар >15 ммоль/л! Проверьте кетоны.' : '💡 Добавлена коррекция.';
        } else {
            statusText = '🟢 Норма';
        }

        // Отображение
        const resultCard = document.getElementById('resultCard');
        resultCard.className = 'result-card';
        if (sugarStatus === 'low') resultCard.classList.add('danger');
        else if (sugarStatus === 'high') resultCard.classList.add('warning');
        
        document.getElementById('resHE').innerText = he.toFixed(2);
        document.getElementById('resFoodInsulin').innerText = foodInsulin.toFixed(1);
        
        const corrSign = correctionInsulin >= 0 ? '+' : '';
        document.getElementById('resCorrection').innerText = `${corrSign}${correctionInsulin.toFixed(1)} ед.`;
        document.getElementById('resCorrection').className = correctionInsulin > 0 ? 'text-red' : (correctionInsulin < 0 ? 'text-green' : '');
        
        document.getElementById('resTotalInsulin').innerText = totalInsulin.toFixed(1);
        
        document.getElementById('correctionInfo').innerHTML = `
            <strong>📊 Детали расчета:</strong><br>
            • Углеводов в порции: ${totalCarbs.toFixed(1)}г<br>
            • Цель сахара: ${targetMin}-${targetMax} ммоль/л<br>
            • Отклонение: ${sugarDiff >= 0 ? '+' : ''}${sugarDiff.toFixed(1)} ммоль/л<br>
            • 1 ед. инсулина снижает на ${sensitivity} ммоль/л
        `;
        
        const warningBox = document.getElementById('warningBox');
        if (warningMsg) {
            warningBox.className = `warning-box show ${sugarStatus === 'low' ? 'hypo' : 'hyper'}`;
            warningBox.innerText = warningMsg;
        } else {
            warningBox.className = 'warning-box';
        }
        
        resultCard.style.display = 'block';
        resultCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        // История
        addToHistory({
            name: productName,
            weight: weight,
            he: he.toFixed(2),
            sugar: currentSugar,
            sugarStatus: sugarStatus,
            foodInsulin: foodInsulin.toFixed(1),
            correction: correctionInsulin.toFixed(1),
            totalInsulin: totalInsulin.toFixed(1),
            time: new Date().toLocaleTimeString('ru-RU', {hour: '2-digit', minute:'2-digit'})
        });
    }

    // === История ===
    function addToHistory(entry) {
        const history = JSON.parse(localStorage.getItem('diabHistory')) || [];
        history.unshift(entry);
        if (history.length > 100) history.pop();
        localStorage.setItem('diabHistory', JSON.stringify(history));
        renderHistory();
    }

    function renderHistory() {
        const list = document.getElementById('historyList');
        const history = JSON.parse(localStorage.getItem('diabHistory')) || [];
        
        list.innerHTML = '';
        
        if (history.length === 0) {
            list.innerHTML = '<li style="padding:20px; color:#999; text-align:center">История пуста</li>';
            updateTotalSummary(0, 0, 0);
            return;
        }

        let totalHe = 0, totalIns = 0;
        
        history.forEach(item => {
            totalHe += parseFloat(item.he);
            totalIns += parseFloat(item.totalInsulin);
            
            const li = document.createElement('li');
            li.className = 'history-item';
            li.innerHTML = `
                <div class="history-left">
                    <strong>${item.name}</strong>
                    <span class="history-time">${item.time} • ${item.sugar} ммоль/л 
                        <span class="status-badge status-${item.sugarStatus}">${item.sugarStatus === 'low' ? '🔴' : item.sugarStatus === 'high' ? '🟡' : '🟢'}</span>
                    </span>
                </div>
                <div class="history-right">
                    <div class="history-he">${item.he} ХЕ</div>
                    <div class="history-ins">💉 ${item.totalInsulin} ед.</div>
                </div>
            `;
            list.appendChild(li);
        });
        
        updateTotalSummary(totalHe, totalIns, history.length);
    }

    function updateTotalSummary(he, ins, count) {
        document.getElementById('totalHe').innerText = he.toFixed(1);
        document.getElementById('totalIns').innerText = ins.toFixed(1);
        document.getElementById('totalRecords').innerText = count;
    }

    function clearHistory() {
        if(confirm('Удалить ВСЮ историю?')) {
            localStorage.removeItem('diabHistory');
            renderHistory();
        }
    }
</script>

